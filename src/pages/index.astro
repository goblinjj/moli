---
import Layout from "../layouts/Layout.astro";
import Calculator from "../components/Calculator";
import type { Recipe, Gem } from "../lib/types";

import swordData from "../data/sword.json";
import axeData from "../data/axe.json";
import spearData from "../data/spear.json";
import bowData from "../data/bow.json";
import staffData from "../data/staff.json";
import daggerData from "../data/dagger.json";
import throwData from "../data/throw.json";
import bombData from "../data/bomb.json";
import helmetData from "../data/helmet.json";
import hatData from "../data/hat.json";
import armorData from "../data/armor.json";
import clothData from "../data/cloth.json";
import robeData from "../data/robe.json";
import bootsData from "../data/boots.json";
import shoesData from "../data/shoes.json";
import shieldData from "../data/shield.json";
import cookingData from "../data/cooking.json";
import pharmacyData from "../data/pharmacy.json";
import accessoryData from "../data/accessory.json";
import dragonData from "../data/dragon.json";
import fiveCData from "../data/fiveC.json";
import scrollData from "../data/scroll.json";
import collarData from "../data/collar.json";
import crystalData from "../data/crystal.json";
import petArmorData from "../data/petArmor.json";
import petAccessoryData from "../data/petAccessory.json";
import petClothData from "../data/petCloth.json";

import generalGemData from "../data/gems/generalGem.json";
import taskGemData from "../data/gems/taskGem.json";
import rubyGemData from "../data/gems/rubyGem.json";
import petGemData from "../data/gems/petGem.json";

const recipes = [
  ...swordData, ...axeData, ...spearData, ...bowData, ...staffData,
  ...daggerData, ...throwData, ...bombData,
  ...helmetData, ...hatData, ...armorData, ...clothData, ...robeData,
  ...bootsData, ...shoesData, ...shieldData,
  ...cookingData, ...pharmacyData, ...accessoryData,
  ...dragonData, ...fiveCData, ...scrollData,
  ...collarData, ...crystalData, ...petArmorData, ...petAccessoryData, ...petClothData,
] as Recipe[];

const gems = [
  ...generalGemData, ...taskGemData, ...rubyGemData, ...petGemData,
] as Gem[];
---

<Layout>
  <Calculator client:load recipes={recipes} gems={gems} />
</Layout>
